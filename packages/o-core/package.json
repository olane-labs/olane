{
  "name": "@olane/o-core",
  "version": "0.8.21",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./streaming": {
      "types": "./dist/src/streaming/index.d.ts",
      "default": "./dist/src/streaming/index.js"
    },
    "./utils/streaming.utils": {
      "types": "./dist/src/utils/streaming.utils.d.ts",
      "default": "./dist/src/utils/streaming.utils.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "aegir test",
    "test:node": "aegir test -t node",
    "test:browser": "aegir test -t browser",
    "deep:clean": "rm -rf node_modules && rm package-lock.json",
    "dev": "DEBUG=o-protocol:* npx tsx src/tests/index.ts",
    "build": "rm -rf dist && tsc",
    "start:prod": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "lint": "aegir lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olane-labs/olane.git"
  },
  "author": "Olane Inc.",
  "license": "(MIT OR Apache-2.0)",
  "description": "Olane addressable p2p node used to host tools, data or anything else your heart can dream of.",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^10.0.1",
    "@tsconfig/node20": "^20.1.9",
    "@types/debug": "^4.1.12",
    "@types/jest": "^30.0.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "aegir": "^47.0.26",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@olane/o-config": "0.8.21",
    "@olane/o-context": "0.8.21",
    "@olane/o-protocol": "0.8.21",
    "chalk": "^5.6.2",
    "debug": "^4.4.3",
    "dotenv": "^17.3.1",
    "multiformats": "^13.4.2",
    "stream-json": "^1.9.1",
    "uuid": "^11.0.0"
  },
  "gitHead": "66cd4f8d3987c01d42809692db23be4218ef863b"
}
