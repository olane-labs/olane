{
  "name": "@olane/o-tool-registry",
  "version": "0.8.20",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "aegir test",
    "test:node": "aegir test -t node",
    "test:browser": "aegir test -t browser",
    "deep:clean": "rm -rf node_modules && rm package-lock.json",
    "dev": "npm run build --prefix ../o-core && npm run build --prefix ../o-tool && npm run build --prefix ../o-tools-common && DEBUG=o-protocol:* npx tsx src/index.ts",
    "build": "tsc",
    "start:prod": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "lint": "aegir lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olane-labs/olane.git"
  },
  "author": "oLane Inc.",
  "license": "(MIT OR Apache-2.0)",
  "description": "oLane server tool registry",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^10.0.1",
    "@tsconfig/node20": "^20.1.9",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "aegir": "^47.0.26",
    "chai": "^6.2.2",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.5.2",
    "@langchain/community": "0.3.47",
    "@langchain/core": "0.3.61",
    "@olane/o-config": "0.8.20",
    "@olane/o-core": "0.8.20",
    "@olane/o-intelligence": "0.8.20",
    "@olane/o-lane": "0.8.20",
    "@olane/o-mcp": "0.8.20",
    "@olane/o-node": "0.8.20",
    "@olane/o-protocol": "0.8.20",
    "@olane/o-tool": "0.8.20",
    "@olane/o-tools-common": "0.8.20",
    "debug": "^4.4.1",
    "dotenv": "^16.5.0",
    "langchain": "0.3.29"
  },
  "gitHead": "66cd4f8d3987c01d42809692db23be4218ef863b"
